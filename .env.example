# OMNIS — Environment variables for portability
# Copy to .env and adjust paths for your environment.
# None of these are required if you run from ~/omnis-control with default structure.

# Root of the omnis-control repository (default: ~/omnis-control)
# OMNIS_ROOT=/home/user/omnis-control

# Claude Code config directory (default: ~/.claude)
# CLAUDE_DIR=/home/user/.claude

# Skills directory override — takes precedence over OMNIS_ROOT/skills and CLAUDE_DIR/skills
# OMNIS_SKILLS_PATH=/home/user/.claude/skills

# External project directories (default: ~/project-name)
# DAILY_PROPHET_DIR=/home/user/daily-prophet-hotels
# LLM_ROUTER_DIR=/home/user/llm-router
# PUBLISHER_OS_DIR=/home/user/publisher-os
# JARVIS_OS_DIR=/home/user/JARVIS_OS

# Obsidian vault path (default: ~/Desktop/ARQUIVOS_MANUS_CLAUDE/OBSIDIAN/ComandoCentral)
# OBSIDIAN_VAULT=/home/user/obsidian/vault

# API auth for KRATOS -> OMNIS v1 routes
# Same secret expected in X-KRATOS-KEY (and temporary aliases)
# OMNIS_API_KEY=coloque_aqui
