    },
    "required": ["target"]
  },
  "outputs_schema": {
    "type": "object",
    "properties": {
      "findings": { "type": "array", "items": { "type": "string" } },
      "verdict": { "type": "string", "enum": ["pass", "flag", "block"] }
    },
    "required": ["findings", "verdict"]
  },
  "approval_required": false,
  "lifecycle": "production",
  "sandbox_policy": "default",
  "created_at": "2026-05-24T00:00:00Z",
